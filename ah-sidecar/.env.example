# ERA Auction House Sidecar — Environment Variables
# Copy this to .env and fill in your values.
# On Pterodactyl, you can also set these as server environment variables
# in the panel instead of using a .env file.

# ── MySQL connection ──────────────────────────────────────────────────────────
# Pterodactyl's MySQL host is usually 127.0.0.1 on the same node,
# or the internal IP shown in your panel's database tab.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=era_ah
DB_PASS=changeme
DB_NAME=era_ah

# ── Server startup ───────────────────────────────────────────────────────────
# Override the default STR binary path if needed (default: /home/server/SkyrimTogetherServer)
# STR_START_CMD=/home/server/SkyrimTogetherServer

# Override Node.js path if auto-detection fails
# NODE_BIN=/home/container/.node/bin/node
