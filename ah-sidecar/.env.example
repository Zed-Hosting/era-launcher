# ERA Auction House Sidecar — Environment Variables
# Copy this to .env and fill in your values.
# On Pterodactyl, you can also set these as server environment variables
# in the panel instead of using a .env file.

# ── MySQL connection ──────────────────────────────────────────────────────────
# Pterodactyl's MySQL host is usually 127.0.0.1 on the same node,
# or the internal IP shown in your panel's database tab.
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=era_ah
DB_PASS=changeme
DB_NAME=era_ah

# ── Sidecar settings ──────────────────────────────────────────────────────────
# Port the REST API listens on (Launcher connects to this)
AH_PORT=3001

# Paths to the file queues shared with the Lua script.
# Relative to the sidecar's working directory (i.e. the container root).
AH_QUEUE_IN=./queue/in
AH_QUEUE_OUT=./queue/out
