{
  "name": "era-launcher",
  "version": "0.1.84",
  "private": true,
  "description": "ERA Launcher — install prereqs, sync curated modlists, run the server, and launch Skyrim Together Reborn.",
  "author": "era-launcher",
  "main": "out/main/index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Zed-Hosting/era-launcher.git"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "start": "electron-vite preview",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:dir": "electron-vite build && electron-builder --dir",
    "pack:win": "electron-vite build && electron-builder --win",
    "release": "electron-vite build && electron-builder --win --publish always"
  },
  "dependencies": {
    "7zip-bin": "^5.2.0",
    "@iarna/toml": "^2.2.5",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.3.9",
    "got": "^14.4.5",
    "keytar": "^7.9.0",
    "node-7z": "^3.0.0",
    "win-version-info": "^6.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electron-toolkit/preload": "^3.0.1",
    "@electron-toolkit/utils": "^3.0.0",
    "@types/node": "^22.10.5",
    "@types/node-7z": "^2.1.10",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@typescript-eslint/eslint-plugin": "^8.20.0",
    "@typescript-eslint/parser": "^8.20.0",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.18.0",
    "lucide-react": "^0.469.0",
    "postcss": "^8.5.1",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8",
    "zustand": "^5.0.2"
  }
}
